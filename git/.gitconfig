[user]
	email = shawnzhongchn@gmail.com
	name = ShawnZhong

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

[delta "lazygit"]
	side-by-side = false

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
